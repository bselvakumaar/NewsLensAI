# Environment Configuration Example
# Copy to .env and fill in your API keys

# ==================== News API Configuration ====================

# NewsAPI.org - Free tier: 100 requests/day
# Get key at: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# The Guardian API (Optional - currently experiencing issues)
# Get key at: https://www.theguardian.com/open-platform
# GUARDIAN_API_KEY=your_guardian_key_here

# ==================== Google Cloud Configuration ====================

GCP_PROJECT_ID=newslensai-mvp
ENV=development
PORT=8000

# ==================== Database Configuration ====================

DATABASE_URL=postgresql://user:password@localhost:5432/newslensai

# ==================== Redis Configuration ====================

REDIS_URL=redis://localhost:6379/0

# ==================== Auto Ingestion Configuration ====================
# Enables periodic web ingestion so chat/news use fresher context
AUTO_INGEST_ENABLED=true
AUTO_INGEST_INTERVAL_MINUTES=15

# External scheduler controls
# If false, /api/admin/ingest/scheduler-trigger returns skipped.
EXTERNAL_INGESTION_ENABLED=true
# Optional bearer token used by Cloud Scheduler in Authorization header.
SCHEDULER_INGEST_TOKEN=replace_with_long_random_secret
