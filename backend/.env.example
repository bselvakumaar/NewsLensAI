# Environment Configuration Example
# Copy to .env and fill in your API keys

# ==================== News API Configuration ====================

# NewsAPI.org - Free tier: 100 requests/day
# Get key at: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# The Guardian API (Optional - currently experiencing issues)
# Get key at: https://www.theguardian.com/open-platform
# GUARDIAN_API_KEY=your_guardian_key_here

# ==================== Google Cloud Configuration ====================

GCP_PROJECT_ID=newslensai-mvp
ENV=development
PORT=8000

# ==================== Database Configuration ====================

DATABASE_URL=postgresql://user:password@localhost:5432/newslensai

# ==================== Redis Configuration ====================

REDIS_URL=redis://localhost:6379/0
